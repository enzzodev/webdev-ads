<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Projeto Web</title>

<style>

body{
    margin:0;
    font-family: Arial, Helvetica, sans-serif;
    background-color:#2f5597;
    color:white;
}

/* NAVBAR */

.navbar{
    background:#111;
    padding:15px 40px;
    display:flex;
    justify-content:flex-start;
    align-items:center;
    gap:10px;
    position:fixed;
    width:100%;
    top:0;
}

.navbar a{
    text-decoration:none;
    color:white;
    background:#2563eb;
    padding:10px 22px;
    border-radius:6px;
    font-weight:bold;
    transition: all 0.3s ease;
    box-shadow:0 3px 6px rgba(0,0,0,0.2);
}

.navbar a:hover{
    background:#1d4ed8;
    transform:translateY(-3px) scale(1.05);
    box-shadow:0 6px 15px rgba(0,0,0,0.4);
}

/* CONTAINER */

.container{
    margin-top:100px;
    max-width:900px;
    margin-left:auto;
    margin-right:auto;
    padding:20px;
}

/* CARDS */

.card{
    background:rgba(0,0,0,0.2);
    padding:30px;
    border-radius:10px;
    margin-bottom:30px;
    box-shadow:0 5px 15px rgba(0,0,0,0.2);
}

/* LISTA */

ul{
    list-style:none;
    padding:0;
    font-size:18px;
}

/* FOOTER */

footer{
    text-align:center;
    padding:20px;
    background:#111;
    margin-top:40px;
}

</style>

</head>

<body>

<div class="navbar">
    <a href="/">Home</a>
    <a href="/sobre">Sobre</a>
    <a href="/contato">Contato</a>
</div>

<div class="container">
    {{{body}}}
</div>

<footer>
Projeto Web • ADS UNILAGO • 2026
</footer>

</body>
</html>